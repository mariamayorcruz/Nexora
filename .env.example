# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nexora_db"
DIRECT_URL="postgresql://user:password@localhost:5432/nexora_db"

# Domain
NEXT_PUBLIC_DOMAIN="https://gotnexora.com"
# URL canónica de la app (prioritaria para enlaces en correos, masterclass, PDF, CRM follow-ups). Producción: siempre definir.
NEXT_PUBLIC_APP_URL="https://www.gotnexora.com"
# URL pública de Calendly u otra reserva (solo https). Opcional: emails de auditoría y pantalla de gracias.
# NEXT_PUBLIC_AUDIT_MEETING_URL="https://calendly.com/tu-equipo/15min"
CONNECT_OAUTH_REDIRECT_BASE_URL="https://gotnexora.com"
# Alternativa si necesitas otro origen para OAuth/redirects (si no, usa NEXT_PUBLIC_APP_URL).
# APP_BASE_URL="https://www.gotnexora.com"

# NextAuth
NEXTAUTH_URL="https://gotnexora.com"
NEXTAUTH_SECRET="your-secret-key-here"

# JWT Secret
JWT_SECRET="your-jwt-secret-here"

# GotNexora provisioning webhook
GOTNEXORA_WEBHOOK_SECRET="your-shared-webhook-secret"
NEXORA_STUDIO_LOGIN_URL="https://www.gotnexora.com/auth/login"

# Admin and founder access
ADMIN_EMAILS="info.emprendeelegante@gmail.com"
FOUNDER_EMAILS="info.emprendeelegante@gmail.com,mayorexcelsiorllc@gmail.com"
FOUNDER_PLAN="enterprise"
FOUNDER_TRIAL_DAYS="365"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_key"
STRIPE_SECRET_KEY="sk_test_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRICE_STARTER_MONTHLY="price_1TKGzfPclnyOiA5fPRKRYTRk"
STRIPE_PRICE_STARTER_YEARLY="price_1TKH1vPclnyOiA5fk52c786H"
STRIPE_PRICE_PROFESSIONAL_MONTHLY="price_1TKH34PclnyOiA5fewR0cliB"
