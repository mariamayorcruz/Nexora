# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nexora_db"

# Domain
NEXT_PUBLIC_DOMAIN="https://gotnexora.com"

# NextAuth
NEXTAUTH_URL="https://gotnexora.com"
NEXTAUTH_SECRET="your-secret-key-here"

# JWT Secret
JWT_SECRET="your-jwt-secret-here"

# Admin and founder access
ADMIN_EMAILS="info.emprendeelegante@gmail.com"
FOUNDER_EMAILS="info.emprendeelegante@gmail.com"
FOUNDER_PLAN="enterprise"
FOUNDER_TRIAL_DAYS="365"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_key"
STRIPE_SECRET_KEY="sk_test_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# API URLs
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Email (optional - for notifications)
EMAIL_FROM="noreply@saleads.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Ad Platform API Keys (Template - users will fill)
# Instagram
INSTAGRAM_BUSINESS_ACCOUNT_TOKEN="placeholder"
# Facebook
FACEBOOK_APP_ID="placeholder"
FACEBOOK_APP_SECRET="placeholder"
# Google
GOOGLE_ADS_CLIENT_ID="placeholder"
GOOGLE_ADS_CLIENT_SECRET="placeholder"
# TikTok
TIKTOK_CLIENT_ID="placeholder"
TIKTOK_CLIENT_SECRET="placeholder"
