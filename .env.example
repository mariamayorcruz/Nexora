# API URLs
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Email (optional - for notifications)
EMAIL_FROM="Nexora <info.emprendeelegante@gmail.com>"
SUPPORT_EMAIL="info.emprendeelegante@gmail.com"
# En Vercel suele ser más simple usar Resend (https://resend.com) en lugar de SMTP:
# RESEND_API_KEY="re_..."
# RESEND_FROM="GotNexora <onboarding@tudominio.com>"
# Si el dominio aún no está verificado en Resend, usa temporalmente:
# RESEND_USE_TEST_FROM="1"
# (envía desde onboarding@resend.dev; quita cuando DNS esté OK)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="info.emprendeelegante@gmail.com"
SMTP_PASS="your-app-password"
NEXT_PUBLIC_APP_DOWNLOAD_URL=""

# Video render provider (optional - required for real text-to-video / image-to-video / avatar video)
VIDEO_RENDER_PROVIDER="heygen"
VIDEO_RENDER_API_KEY="your-video-provider-api-key"
VIDEO_RENDER_API_URL=""
HEYGEN_API_KEY="your-heygen-api-key"
RUNWAY_API_KEY="your-runway-api-key"
PEXELS_API_KEY=""
PIXABAY_API_KEY=""
ADMIN_CODE_MODEL="gpt-4.1-mini"

# Support assistant providers (optional)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# Supabase Storage (recommended for video uploads in production)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="nexora-videos"
SUPABASE_STORAGE_SIGNED_URL_SECONDS="604800"

