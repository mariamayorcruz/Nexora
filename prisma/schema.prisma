// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  name              String?
  password          String
  image             String?
  emailVerified     DateTime?
  marketingOptIn    Boolean      @default(false)
  marketingOptInAt  DateTime?
  nurtureStatus     String       @default("not-consented")
  lastNurtureSentAt DateTime?
  nextNurtureSendAt DateTime?
  /// Primera vez que la suscripción entró en estado pagado (active/trial) vía sync webhook.
  onboardingStartedAt DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  subscription      Subscription?
  adAccounts        AdAccount[]
  campaigns         Campaign[]
  crmLeads          CrmLead[]
  crmSettings       CrmWorkspaceSettings?
  aiUsageBuckets    AiWorkspaceUsage[]
  aiJobs            AiWorkspaceJob[]
  videoProjects     AiVideoProject[]
  videoProjectVersions AiVideoProjectVersion[]
  videoAssets       AiVideoAsset[]
  leadCaptures      LeadCapture[]
  connectionRequests ConnectionRequest[]
  invoices          Invoice[]
}

model Subscription {
  id                String       @id @default(cuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              String       @default("starter") // starter, pro, enterprise
  status            String       @default("active") // active, cancelled, paused
  currentPeriodStart DateTime
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean      @default(false)
  stripeCustomerId  String?      @unique
  stripeSubId       String?      @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model AdAccount {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String       // instagram, facebook, google, tiktok
  accountId         String
  accessToken       String       @db.Text
  refreshToken      String?      @db.Text
  expiresAt         DateTime?
  accountName       String
  accountEmail      String?
  connected         Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  campaigns         Campaign[]

  @@unique([userId, platform, accountId])
}

model Campaign {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccountId       String
  adAccount         AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  name              String
  description       String?      @db.Text
  budget            Float
  startDate         DateTime
  endDate           DateTime?
  status            String       // active, paused, completed
  targeting         Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  analytics         Analytics?
  crmLeads          CrmLead[]
}

model Analytics {
  id                String       @id @default(cuid())
  campaignId        String       @unique
  campaign          Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  impressions       Int          @default(0)
  clicks            Int          @default(0)
  conversions       Int          @default(0)
  spend             Float        @default(0)
  revenue           Float        @default(0)
  ctr               Float        @default(0)
  cpc               Float        @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Invoice {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeInvoiceId   String?      @unique
  amount            Float
  currency          String       @default("USD")
  description       String?
  status            String       // draft, open, paid, void, uncollectible
  periodStart       DateTime
  periodEnd         DateTime
  dueDate           DateTime?
  paidAt            DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model CrmLead {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  company         String?
  source          String   @default("manual")
  stage           String   @default("lead")
  status          String   @default("nuevo")
  value           Float    @default(0)
  confidence      Int      @default(25)
  nextAction      String?
  notes           String?  @db.Text
  lastContactedAt DateTime?
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CrmWorkspaceSettings {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAutomationEnabled Boolean  @default(true)
  whatsappEnabled        Boolean  @default(false)
  phoneEnabled           Boolean  @default(false)
  externalCrmEnabled     Boolean  @default(false)
  externalCrmName        String?
  autoFollowUpEnabled    Boolean  @default(true)
  defaultCadence         String   @default("48h")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AiWorkspaceUsage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleKey        String
  cycleStart      DateTime
  cycleEnd        DateTime
  creditsIncluded Int
  creditsPurchased Int     @default(0)
  creditsUsed     Int      @default(0)
  lastJobAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, cycleKey])
}

model AiWorkspaceJob {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool        String
  title       String
  prompt      String   @db.Text
  channel     String?
  status      String   @default("completed")
  creditsUsed Int
  output      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiVideoProject {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  tool         String                  @default("text-to-video")
  prompt       String                  @db.Text
  outputFormat String                  @default("vertical 9:16")
  captionStyle String                  @default("bold clean")
  status       String                  @default("draft")
  timeline     Json?
  versions     AiVideoProjectVersion[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([userId, updatedAt])
}

model AiVideoProjectVersion {
  id         String         @id @default(cuid())
  projectId  String
  project    AiVideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  version    Int
  note       String?
  timeline   Json
  renderPlan Json?
  createdAt  DateTime       @default(now())

  @@unique([projectId, version])
  @@index([userId, createdAt])
}

model AiVideoAsset {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   @default("library")
  title       String
  url         String
  relativeUrl String?
  storageKey  String?
  mimeType    String?
  sizeBytes   Int?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
}

model LeadCapture {
  id         String   @id @default(cuid())
  email      String
  name       String?
  source     String   @default("masterclass")
  resource   String   @default("el-mapa-de-decisiones-48-horas")
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  crmLeadId  String?
  convertedToCrmAt DateTime?
  // Funnel admin: marca pago vía webhook Stripe por email (no asigna CRM a otro tenant).
  paid              Boolean   @default(false)
  convertedToPaidAt DateTime?
  /// Coincide con AttributionSession.trackerId cuando el lead llegó con cookies nxa_tid / nxa_sid.
  trackerId         String?
  /// Recuperación comercial: lead sin pago tras umbral (ver `applyUnpaidLeadRecoveryFlags`); no envía email solo.
  needsSalesFollowup   Boolean   @default(false)
  salesFollowupMarkedAt DateTime?
  /// Primer correo de recuperación enviado (evita reenvíos en corridas posteriores).
  salesRecoveryFollowupSentAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email, source])
  @@index([paid])
  @@index([trackerId])
  @@index([needsSalesFollowup, createdAt])
  @@index([needsSalesFollowup, salesRecoveryFollowupSentAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PaymentSettings {
  id                String   @id @default(cuid())
  stripeWebhookSecret String?
  bankAccount       Json?
  paypalEmail       String?
  commissionRate    Float    @default(2.9)
  minimumPayout     Float    @default(25.0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model ConnectionRequest {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         String
  businessName     String?
  contactEmail     String?
  adAccountLabel   String?
  websiteUrl       String?
  notes            String?  @db.Text
  setupPreference  String   @default("oauth")
  status           String   @default("pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, platform, status])
}

model AdminWorkspaceConfig {
  id              String   @id @default(cuid())
  key             String   @unique @default("main")
  funnelConfig    Json?
  emailTemplates  Json?
  automationConfig Json?
  roadmapConfig   Json?
  platformConfig  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AttributionSession {
  id              String             @id @default(cuid())
  trackerId       String             @unique
  sessionKey      String             @unique
  landingPath     String?
  referrer        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  gclid           String?
  fbclid          String?
  ttclid          String?
  msclkid         String?
  firstSeenAt     DateTime           @default(now())
  lastSeenAt      DateTime           @default(now())
  consentStatus   String             @default("unknown")
  consentUpdatedAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  events          AttributionEvent[]

  @@index([createdAt])
  @@index([utmSource, utmCampaign])
}

model AttributionEvent {
  id                   String             @id @default(cuid())
  attributionSessionId String
  session              AttributionSession @relation(fields: [attributionSessionId], references: [id], onDelete: Cascade)
  trackerId            String
  sessionKey           String
  eventName            String
  eventType            String             @default("custom")
  path                 String?
  source               String?
  value                Float?
  currency             String?
  dedupKey             String             @unique
  payload              Json?
  eventTs              DateTime           @default(now())
  createdAt            DateTime           @default(now())

  @@index([attributionSessionId, eventTs])
  @@index([eventName, createdAt])
}
